# Public domain and TLS contact
DOMAIN_NAME=example.com
DOMAIN_SERVER_NAMES=example.com
LETSENCRYPT_EMAIL=you@example.com

# Host paths on the EC2 instance
APP_ROOT=/opt/risk-atlas/app
WEB_ROOT_DIR=/var/www/risk-atlas
POSTGRES_DATA_DIR=/var/lib/risk-atlas/postgres
ARTIFACT_ROOT_DIR=/var/lib/risk-atlas/artifacts
ARTIFACT_CACHE_DIR=/var/lib/risk-atlas/artifacts/cache

# API and web runtime
NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=3000
WEB_PORT=443
VITE_API_BASE_URL=
VITE_REPOSITORY_URL=https://github.com/YongzeYang/Risk-Atlas-A-Market-Relationship-Artifact-Platform
CORS_ALLOWED_ORIGINS=https://example.com
ARTIFACT_STORAGE_BACKEND=s3
S3_SIGNED_URL_TTL_SECONDS=900

# PostgreSQL
POSTGRES_DB=risk_atlas
POSTGRES_USER=risk_atlas
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://risk_atlas:change-this-password@postgres:5432/risk_atlas?schema=public

# Risk Atlas application secrets
RISK_ATLAS_INVITE_CODES=replace-with-your-own-invite-codes
RISK_ATLAS_INVITE_SALT=replace-with-a-long-random-salt

# C++ binaries inside the API container
BSM_WRITER_BIN=/opt/risk-atlas/bin/risk_atlas_bsm_writer
BSM_QUERY_BIN=/opt/risk-atlas/bin/risk_atlas_bsm_query

# S3 backup and archive settings
AWS_REGION=us-east-1
S3_ARTIFACT_BUCKET=replace-with-your-bucket-name
S3_ARTIFACT_PREFIX=prod
SYNC_ANALYSIS_RUNS_TO_S3=0
SYNC_ARTIFACTS_ON_DEPLOY=0
S3_SYNC_DELETE=0

# Optional first-deploy helpers
RUN_SEED_ON_DEPLOY=0
