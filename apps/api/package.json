{
  "name": "@risk-atlas/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate-sample-eod": "tsx prisma/generate-sample-eod.ts",
    "db:import-eod": "tsx prisma/import-eod.ts",
    "db:refresh-real-hk-taxonomy": "tsx prisma/real-hk-benchmark.ts --taxonomy-only",
    "db:benchmark-real-hk": "tsx prisma/real-hk-benchmark.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test:smoke": "node --import tsx --test src/test/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/static": "^9.1.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "xlsx": "^0.18.5"
  }
}