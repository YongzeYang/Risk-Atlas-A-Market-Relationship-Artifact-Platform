datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ScoreMethod {
  pearson_corr
}

enum BuildStatus {
  pending
  running
  succeeded
  failed
}

enum ArtifactStorageKind {
  local_fs
  s3
}

enum DatasetSource {
  curated_csv
}

enum Market {
  HK
}

enum SecurityType {
  common_equity
  etf
  reit
  warrant
  cbbc
  stapled_security
}

enum Sector {
  financials
  property
  tech
  telecom
  industrial
  utilities
  energy
  consumer
}

enum UniverseDefinitionKind {
  static
  liquidity_top_n
  sector_filter
  all_common_equity
}

enum SeriesFrequency {
  daily
  weekly
  monthly
}

enum BuildSeriesStatus {
  pending
  running
  succeeded
  partially_failed
  failed
}

model SecurityMaster {
  symbol       String       @id
  name         String
  shortName    String?
  securityType SecurityType
  sector       Sector?
  market       Market
  createdAt    DateTime     @default(now())

  @@map("security_master")
}

model Dataset {
  id                      String          @id @default(cuid())
  name                    String
  source                  DatasetSource
  market                  Market
  catalogSymbolCount      Int             @default(0)
  catalogPriceRowCount    BigInt          @default(0)
  catalogMinTradeDate     String?         @db.VarChar(10)
  catalogMaxTradeDate     String?         @db.VarChar(10)
  catalogFirstValidAsOf60 String?         @db.VarChar(10)
  catalogFirstValidAsOf120 String?        @db.VarChar(10)
  catalogFirstValidAsOf252 String?        @db.VarChar(10)
  createdAt               DateTime        @default(now())

  eodPrices   EodPrice[]
  buildRuns   BuildRun[]
  buildSeries BuildSeries[]

  @@map("datasets")
}

model Universe {
  id               String                 @id @default(cuid())
  name             String
  market           Market
  symbolsJson      Json?
  symbolCount      Int?
  definitionKind   UniverseDefinitionKind @default(static)
  definitionParams Json?
  createdAt        DateTime               @default(now())

  buildRuns        BuildRun[]
  buildSeries      BuildSeries[]

  @@map("universes")
}

model EodPrice {
  id        String   @id @default(cuid())
  datasetId String
  tradeDate String   @db.VarChar(10)
  symbol    String
  adjClose  Float
  volume    BigInt?

  dataset   Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId, tradeDate])
  @@index([datasetId, symbol])
  @@map("eod_prices")
}

model BuildRun {
  id                  String       @id @default(cuid())
  datasetId           String
  universeId          String
  seriesId            String?
  asOfDate            String       @db.VarChar(10)
  windowDays          Int
  scoreMethod         ScoreMethod
  status              BuildStatus  @default(pending)
  resolvedSymbolsJson Json?
  createdAt           DateTime     @default(now())
  startedAt           DateTime?
  finishedAt          DateTime?
  errorMessage        String?      @db.Text

  dataset             Dataset      @relation(fields: [datasetId], references: [id], onDelete: Restrict)
  universe            Universe     @relation(fields: [universeId], references: [id], onDelete: Restrict)
  series              BuildSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  artifact            Artifact?

  @@index([status, createdAt])
  @@index([datasetId, asOfDate])
  @@index([universeId, asOfDate])
  @@index([seriesId, asOfDate])
  @@map("build_runs")
}

model Artifact {
  id               String              @id @default(cuid())
  buildRunId       String              @unique
  bundleVersion    Int                 @default(1)
  storageKind      ArtifactStorageKind @default(local_fs)
  storageBucket    String?             @db.VarChar(128)
  storagePrefix    String              @db.Text
  matrixByteSize   BigInt?
  previewByteSize  BigInt?
  manifestByteSize BigInt?
  symbolCount      Int
  minScore         Float?
  maxScore         Float?
  previewStrategy  String              @default("dense_json")
  topPairsJson     Json?
  createdAt        DateTime            @default(now())

  buildRun         BuildRun            @relation(fields: [buildRunId], references: [id], onDelete: Cascade)

  @@index([storageKind, createdAt])
  @@map("artifacts")
}

model BuildSeries {
  id                String            @id @default(cuid())
  name              String
  datasetId         String
  universeId        String
  windowDays        Int
  scoreMethod       ScoreMethod
  startDate         String            @db.VarChar(10)
  endDate           String            @db.VarChar(10)
  frequency         SeriesFrequency
  status            BuildSeriesStatus @default(pending)
  totalRunCount     Int               @default(0)
  completedRunCount Int               @default(0)
  failedRunCount    Int               @default(0)
  createdAt         DateTime          @default(now())
  startedAt         DateTime?
  finishedAt        DateTime?

  dataset           Dataset           @relation(fields: [datasetId], references: [id], onDelete: Restrict)
  universe          Universe          @relation(fields: [universeId], references: [id], onDelete: Restrict)
  buildRuns         BuildRun[]

  @@index([status, createdAt])
  @@map("build_series")
}

model InviteCode {
  id        String   @id @default(cuid())
  codeHash  String   @unique
  label     String?
  usesLeft  Int?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("invite_codes")
}